{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "paths": {
      "@/*": ["./src/*"],
      "@pkg/ai": ["./src/index.ts"],
      "@pkg/core": ["../core/src/index.ts"],
      "@pkg/db": ["../db/src/index.ts"],
      "@pkg/domain": ["../domain/src/index.ts"],
      "@pkg/schema": ["../schema/src/index.ts"]
    },
    "types": ["node", "vitest"]
  },
  "include": ["src/**/*.ts"],
  "references": [{ "path": "../schema" }, { "path": "../domain" }, { "path": "../db" }, { "path": "../core" }]
}
