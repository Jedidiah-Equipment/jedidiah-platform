    "@fastify/static": "^9.1.3",
    "@fontsource-variable/geist": "^5.2.9",
    "@mantine/hooks": "^9.3.0",
    "@pkg/api": "workspace:*",
    "@pkg/domain": "workspace:*",
    "@pkg/schema": "workspace:*",
    "@tabler/icons-react": "3.44.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.0",
