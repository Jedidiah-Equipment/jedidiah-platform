{
  "cli": {
    "version": ">= 20.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "staging": {
      "distribution": "store",
      "channel": "staging",
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "staging",
        "EXPO_PUBLIC_API_BASE_URL": "https://staging-api.jedidiahequipment.co.za"
      },
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://api.jedidiahequipment.co.za"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "staging": {
      "android": {
        "track": "internal"
      },
      "ios": {
        "ascAppId": "6785438770"
      }
    },
    "production": {
      "android": {
        "track": "internal"
      }
    }
  }
}
