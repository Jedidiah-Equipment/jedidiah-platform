{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build All",
      "type": "shell",
      "command": "pnpm",
      "args": ["build"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "icon": {
        "id": "tools",
        "color": "terminal.ansiCyan"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Build Api",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@pkg/api", "build"],
      "group": "build",
      "icon": {
        "id": "tools",
        "color": "terminal.ansiCyan"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Build App",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@pkg/web", "build"],
      "group": "build",
      "icon": {
        "id": "tools",
        "color": "terminal.ansiCyan"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Build Schema",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@pkg/schema", "build"],
      "group": "build",
      "icon": {
        "id": "tools",
        "color": "terminal.ansiCyan"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Build Core",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@pkg/core", "build"],
      "group": "build",
      "icon": {
        "id": "tools",
        "color": "terminal.ansiCyan"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Build Db",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@pkg/db", "build"],
      "group": "build",
      "icon": {
        "id": "tools",
        "color": "terminal.ansiCyan"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Kill Web And Api",
      "type": "shell",
      "command": "pnpm",
      "args": ["kill:web-api"],
      "icon": {
        "id": "debug-stop",
        "color": "terminal.ansiRed"
      },
      "problemMatcher": []
    }
  ]
}
