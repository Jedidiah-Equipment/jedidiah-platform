{
  "name": "@pkg/seed",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "seed:read": "tsx src/seed-reader.ts",
    "seed:write": "tsx src/seed-writer.ts",
    "db:seed": "tsx src/seed-writer.ts",
    "db:reset:remote": "tsx src/reset-remote.ts"
  },
  "dependencies": {
    "@pkg/core": "workspace:*",
    "@pkg/db": "workspace:*",
    "@pkg/domain": "workspace:*",
    "@pkg/schema": "workspace:*",
    "better-auth": "^1.6.14",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "tsx": "^4.22.4"
  }
