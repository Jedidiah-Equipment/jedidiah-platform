{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "types": ["node", "vite/client", "vitest"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/server/**"],
  "references": [{ "path": "../api" }]
}
