# General
NODE_ENV=development
APP_ENV=development

# API
APP_BASE_URL=http://localhost:7001
API_BASE_URL=http://localhost:7002
AUTH_SECRET=dev-auth-secret-must-be-at-least-32-chars
AUTH_TRUSTED_ORIGINS=http://localhost:7001,http://localhost:7002,http://localhost:7003,jedidiahops://,jedidiahopsstaging://
EMAIL_PROVIDER=mock
EMAIL_FROM=noreply@jedidiahequipment.co.za
# RESEND_API_KEY=re_...
DOCUMENT_STORAGE_ACCESS_KEY_ID=minioadmin
DOCUMENT_STORAGE_BUCKET=jedidiah-documents
DOCUMENT_STORAGE_ENDPOINT=http://localhost:9000
DOCUMENT_STORAGE_FORCE_PATH_STYLE=true
DOCUMENT_STORAGE_REGION=us-east-1
DOCUMENT_STORAGE_SECRET_ACCESS_KEY=minioadmin
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low

# Web
APP_BASE_URL=http://localhost:7001
API_BASE_URL=http://localhost:7002
AUTH_BASE_URL=http://localhost:7002/api/auth

# Lander (staging-only Railway service, railway.lander.json)
# Read-only public site; shares the staging DB/bucket the API owns and runs no migrations (ADR 0007).
# Required on the service:
#   APP_ENV=staging                  # keeps the site out of search results (robots Disallow + noindex)
#   DATABASE_URL=<staging Postgres>  # same staging DB the API migrates
#   DOCUMENT_STORAGE_*               # same staging bucket/creds as the API (the six DOCUMENT_STORAGE_ vars above)
# Optional:
#   RESEND_API_KEY=re_...            # enables the contact form; without it pages still render, only sends fail
#   CONTACT_EMAIL_FROM=noreply@jedidiahequipment.co.za  # defaults shown; override per environment
#   CONTACT_EMAIL_TO=info@jedidiahequipment.co.za
#   VITE_POSTHOG_KEY=phc_...         # client analytics token; unset = analytics-free (ingest is same-origin /info proxy, no host var)
#   VITE_SITE_URL=https://...        # absolute origin for sitemap + robots.txt; defaults to the live domain

# DB
DATABASE_URL=postgres://postgres:postgres@localhost:5432/jedidiah
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/jedidiah_template

# Logging
LOG_LEVEL=info
# LOG_DOMAINS_DISABLED=ai,http  # Omit to enable all domains

# PostHog
# Enabled defaults to false in development and true in staging/production.
# POSTHOG_ENABLED=false
# POSTHOG_PROJECT_TOKEN=phc_...

# PostHog source maps (web build)
# Source map upload defaults to enabled when PostHog is enabled.
# POSTHOG_SOURCEMAPS_ENABLED=false
# POSTHOG_API_KEY=phx_...
# POSTHOG_PROJECT_ID=12345
# POSTHOG_SOURCEMAPS_HOST=https://us.posthog.com
