{
  "name": "jedidiah-platform",
  "private": true,
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:kill": "sh scripts/kill-dev-services.sh",
    "dev:kill:all": "sh scripts/kill-dev-services.sh --all",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "compose:up": "sh scripts/compose-up.sh",
    "compose:down": "sh scripts/compose-down.sh",
    "db:up": "pnpm compose:down && pnpm compose:up && pnpm db:migrate && pnpm db:seed",
    "db:up:template": "pnpm compose:up && pnpm --filter @pkg/db db:up:template",
    "db:create": "pnpm --filter @pkg/db db:create",
    "db:generate": "pnpm --filter @pkg/db db:generate",
    "db:migrate": "pnpm --filter @pkg/db build && pnpm --filter @pkg/db db:migrate",
    "db:migrate:test": "pnpm --filter @pkg/db build && NODE_ENV=test pnpm --filter @pkg/db db:migrate",
    "db:seed": "pnpm --filter @pkg/seed db:seed",
    "db:studio": "pnpm --filter @pkg/db db:studio",
    "parallel:up": "sh scripts/parallel-env.sh up",
    "parallel:down": "sh scripts/parallel-env.sh down",
    "update-package-versions": "pnpm up --recursive --interactive",
    "verify": "pnpm lint && pnpm typecheck && pnpm build && pnpm test"
  },
  "dependencies": {
    "@pkg/schema": "workspace:*",
    "better-auth": "^1.6.23",
    "fastify": "^5.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^26.1.1",
    "dotenv": "^17.4.2",
    "shadcn": "^4.13.0",
    "tsx": "^4.23.0",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
