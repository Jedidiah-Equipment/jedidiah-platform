{
  "name": "@pkg/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:up:template": "tsx src/create-test-template.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node dist/migrate.js",
    "db:migrate:dev": "tsx src/migrate.ts",
    "db:migrate:test": "pnpm build && NODE_ENV=test node dist/migrate.js",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@pkg/domain": "workspace:*",
    "@pkg/schema": "workspace:*",
    "better-auth": "^1.6.14",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10"
  }
}
