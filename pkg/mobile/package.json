{
  "name": "@pkg/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "preandroid": "turbo run build --filter=@pkg/api",
    "pretypecheck": "turbo run build --filter=@pkg/api",
    "preios": "turbo run build --filter=@pkg/api",
    "predev": "turbo run build --filter=@pkg/api",
    "android": "APP_VARIANT=staging expo run:android",
    "android:staging-api": "APP_VARIANT=staging EXPO_PUBLIC_API_BASE_URL=https://staging-api.jedidiahequipment.co.za expo run:android",
    "doctor": "APP_VARIANT=staging pnpm dlx expo-doctor",
    "android-eas-submit-production": "APP_VARIANT=production eas build --profile production --platform android --auto-submit",
    "ios-eas-submit-production": "APP_VARIANT=production eas build --profile production --platform ios --auto-submit",
    "android-eas-submit-staging": "APP_VARIANT=staging eas build --profile staging --platform android --auto-submit",
    "ios-eas-submit-staging": "APP_VARIANT=staging eas build --profile staging --platform ios --auto-submit",
    "eas-build-post-install": "pnpm --workspace-root turbo run build --filter=@pkg/schema --filter=@pkg/domain",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "ios": "APP_VARIANT=staging expo run:ios",
    "ios:staging-api": "APP_VARIANT=staging EXPO_PUBLIC_API_BASE_URL=https://staging-api.jedidiahequipment.co.za expo run:ios",
    "dev": "APP_VARIANT=staging expo start --dev-client",
    "dev:staging-api": "APP_VARIANT=staging EXPO_PUBLIC_API_BASE_URL=https://staging-api.jedidiahequipment.co.za expo start --dev-client --clear",
    "test": "vitest run"
  },
  "dependencies": {
    "@better-auth/expo": "1.6.23",
    "@gluestack-ui/nativewind-utils": "1.0.28",
    "@gluestack-ui/overlay": "0.1.22",
    "@gluestack-ui/toast": "1.0.9",
    "@legendapp/motion": "2.5.3",
    "@pkg/domain": "workspace:*",
    "@pkg/schema": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tabler/icons-react-native": "3.44.0",
    "@tanstack/react-form": "1.33.0",
    "@tanstack/react-query": "5.101.0",
    "@trpc/client": "11.18.0",
    "@trpc/tanstack-react-query": "11.18.0",
    "better-auth": "^1.6.23",
    "expo": "^56.0.15",
    "expo-constants": "^56.0.20",
    "expo-dev-client": "^56.0.22",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-linking": "^56.0.15",
    "expo-network": "~56.0.5",
    "expo-router": "^56.2.14",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.21",
    "expo-status-bar": "^56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.21",
    "expo-web-browser": "~56.0.5",
    "nativewind": "4.2.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-blob-util": "0.24.10",
    "react-native-css-interop": "0.2.5",
    "react-native-pdf": "7.0.4",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "7.29.7",
    "@config-plugins/react-native-blob-util": "~14.0.1",
    "@config-plugins/react-native-pdf": "~14.0.1",
    "@pkg/api": "workspace:*",
    "@react-native/metro-config": "0.85.3",
    "@types/react": "~19.2.17",
    "babel-preset-expo": "56.0.15",
    "tailwindcss": "3.4.19",
    "tailwindcss-animate": "1.0.7",
    "typescript": "~6.0.3"
  }
}
