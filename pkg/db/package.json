{
  "name": "@pkg/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./database-client": {
      "types": "./dist/database-client.d.ts",
      "import": "./dist/database-client.js"
    },
    "./test-utils": {
      "types": "./dist/test-utils.d.ts",
      "import": "./dist/test-utils.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:up:template": "tsx src/create-test-template.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node dist/migrate.js",
    "db:migrate:dev": "tsx src/migrate.ts",
    "db:migrate:test": "pnpm build && NODE_ENV=test node dist/migrate.js",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7",
    "dotenv": "^17.4.2",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.5"
  }
}
