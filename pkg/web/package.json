{
  "name": "@pkg/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "tsc -b tsconfig.server.json",
    "start": "node dist-server/server/static.js",
    "preview": "vite preview",
    "typecheck": "pnpm typecheck:client && pnpm typecheck:server",
    "typecheck:client": "tsc -p tsconfig.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run"
  },
