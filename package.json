{
  "name": "jedidiah-platform",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "kill:web-api": "sh scripts/kill-web-api.sh",
    "db:up": "sh -c 'if [ -f .env.dev ]; then docker compose --env-file .env.dev up -d --wait; else docker compose up -d --wait; fi'",
    "db:reset": "docker compose down -v && pnpm db:up && pnpm db:migrate && pnpm db:seed",
    "db:up:template": "pnpm db:up && pnpm --filter @pkg/db db:up:template",
    "db:generate": "pnpm --filter @pkg/db db:generate",
    "db:migrate": "pnpm --filter @pkg/db build && pnpm --filter @pkg/db db:migrate",
    "db:migrate:test": "pnpm --filter @pkg/db build && NODE_ENV=test pnpm --filter @pkg/db db:migrate",
    "db:seed": "pnpm --filter @pkg/seed db:seed",
    "db:studio": "pnpm --filter @pkg/db db:studio",
    "update-package-versions": "pnpm up --recursive --interactive",
    "verify": "pnpm lint && pnpm typecheck && pnpm build && pnpm test"
  },
  "dependencies": {
    "@pkg/schema": "workspace:*",
    "better-auth": "^1.6.14",
    "fastify": "^5.8.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "shadcn": "^4.10.0",
    "tsx": "^4.22.4",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@posthog/cli"
    ],
    "ignoredBuiltDependencies": [
      "core-js",
      "protobufjs",
      "msw"
    ]
  }
}
