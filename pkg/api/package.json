{
  "name": "@pkg/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./router-type": {
      "types": "./dist/router-type.d.ts",
      "default": "./dist/router-type.js"
    }
  },
  "scripts": {
    "dev": "tsx watch --import ../../scripts/load-dev-env.mjs src/main.ts",
    "build": "tsc -b",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run",
    "env:check": "tsx --import ../../scripts/load-dev-env.mjs src/env.ts"
  },
  "dependencies": {
    "@pkg/db": "workspace:*",
    "@pkg/schema": "workspace:*",
    "@better-auth/drizzle-adapter": "^1.4.7",
    "@fastify/cors": "^11.2.0",
    "@trpc/server": "^11.7.2",
    "better-auth": "^1.4.7",
    "fastify": "^5.6.2",
    "zod": "^4.1.12"
  }
}
