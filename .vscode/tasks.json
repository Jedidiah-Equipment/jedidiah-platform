{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build All",
      "type": "shell",
      "command": "pnpm",
      "args": ["turbo", "run", "build"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "icon": {
        "id": "tools",
        "color": "terminal.ansiCyan"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Build Api",
      "type": "shell",
      "command": "pnpm",
      "args": ["turbo", "run", "build", "--filter=@pkg/api"],
      "group": "build",
      "icon": {
        "id": "tools",
        "color": "terminal.ansiCyan"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Build App",
      "type": "shell",
      "command": "pnpm",
      "args": ["turbo", "run", "build", "--filter=@pkg/web"],
      "group": "build",
      "icon": {
        "id": "tools",
        "color": "terminal.ansiCyan"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Build Schema",
      "type": "shell",
      "command": "pnpm",
      "args": ["turbo", "run", "build", "--filter=@pkg/schema"],
      "group": "build",
      "icon": {
        "id": "tools",
        "color": "terminal.ansiCyan"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Build Core",
      "type": "shell",
      "command": "pnpm",
      "args": ["turbo", "run", "build", "--filter=@pkg/core"],
      "group": "build",
      "icon": {
        "id": "tools",
        "color": "terminal.ansiCyan"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Build Db",
      "type": "shell",
      "command": "pnpm",
      "args": ["turbo", "run", "build", "--filter=@pkg/db"],
      "group": "build",
      "icon": {
        "id": "tools",
        "color": "terminal.ansiCyan"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Kill Web And Api",
      "type": "shell",
      "command": "pnpm",
      "args": ["kill:web-api"],
      "icon": {
        "id": "debug-stop",
        "color": "terminal.ansiRed"
      },
      "problemMatcher": []
    }
  ]
}
